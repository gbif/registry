<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="org.gbif.registry.persistence.mapper.collections.AuditLogMapper">

  <!-- Auto-mapping and eager loading of sub resources  -->
  <resultMap id="AUDIT_LOG_DTO_MAP" type="org.gbif.registry.persistence.mapper.collections.dto.AuditLogDto" autoMapping="true">
    <id property="key" column="key"/>
  </resultMap>

  <sql id="AUDIT_LOG_WRITE_FIELDS">
    trace_id, entity_type, entity_key, created, created_by, pre_state, post_state, note
  </sql>

  <sql id="AUDIT_LOG_PARAMS_CREATE">
    #{traceId,jdbcType=OTHER},
    #{entityType,jdbcType=OTHER},
    #{entityKey,jdbcType=OTHER},
    now(), <!-- created -->
    #{createdBy,jdbcType=VARCHAR},
    #{preState,jdbcType=OTHER}::jsonb,
    #{postState,jdbcType=OTHER}::jsonb,
    #{note,jdbcType=VARCHAR}
  </sql>

  <insert id="create" parameterType="org.gbif.registry.persistence.mapper.collections.dto.AuditLogDto" useGeneratedKeys="true" keyProperty="key">
    INSERT INTO grscicoll_audit_log(<include refid="AUDIT_LOG_WRITE_FIELDS"/>)
    VALUES(<include refid="AUDIT_LOG_PARAMS_CREATE"/>)
  </insert>

</mapper>
